{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Next.js Dev Server",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/freelanceai"
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "nextjs",
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".*(starting|compiling).*",
                    "endsPattern": ".*(Ready|started server|localhost:3000).*"
                }
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            }
        }
    ]
}
